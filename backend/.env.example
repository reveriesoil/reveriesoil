# 前端访问地址（本地部署默认无需修改）
FRONTEND_URL=http://localhost:3000

# 允许跨域的来源（逗号分隔，为空则使用默认值）
CORS_ALLOW_ORIGINS=

# 数据库路径（默认 SQLite 文件存储在容器内，如需持久化请使用 volume）
DATABASE_URL=sqlite+aiosqlite:///./dreamit.db

# 静态文件存储目录（图片、音频）
STATIC_DIR=./static

# ── AI 模型配置（在前端设置界面填写后会自动保存到数据库，无需在此配置）──
# 以下变量仅在您希望通过环境变量预设配置时使用
# TEXT_API_KEY=your_deepseek_api_key
# TEXT_MODEL=deepseek-v3-0324
# TEXT_ENDPOINT=https://api.deepseek.com/v1
# IMAGE_PROVIDER=jimeng
# IMAGE_ACCESS_KEY_ID=your_jimeng_access_key
# IMAGE_ACCESS_KEY_SECRET=your_jimeng_secret
